# ============================================================
#  Configuración de entorno — IPP UPTAG
#  Copia este archivo como .env y completa los valores reales.
#  NUNCA subas .env al repositorio de git.
# ============================================================

# Base de datos
DB_HOST=localhost
DB_NAME=ippuptag
DB_USER=ipp_app
DB_PASS=contraseña_fuerte_aqui
DB_CHARSET=utf8mb4

# Entorno de la aplicación: development | production
APP_ENV=development

# URL base canónica del portal (raíz del proyecto, SIN barra final).
# Se usa para construir los enlaces de los correos de verificación y
# recuperación. Si se deja vacío, se usa el host de la petición (menos
# seguro: vulnerable a Host header injection).
#   XAMPP local → http://localhost/uptag_v9
#   producción  → https://portal.uptag.edu.ve
APP_URL=

# Ruta absoluta donde se guardan los archivos subidos.
# En desarrollo (XAMPP) usa la ruta relativa al proyecto.
# En producción, mueve esta carpeta FUERA del webroot.
# Ejemplo Linux: /var/www/ipp-uploads/reembolsos
UPLOAD_PATH=

# Correo saliente (PHPMailer / SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@uptag.edu.ve
MAIL_PASS=contraseña_smtp_aqui
MAIL_FROM_NAME=IPP UPTAG

# Proveedores de integración externa (fronteras con otros sistemas).
#   mock = usa las tablas locales agremiado / estado_afiliacion_cache /
#          consulta_ledger_cache / tarifa_cache (se llenan a mano para pruebas).
# Cuando exista la integración real, se agregará el driver correspondiente
# (ver INTEGRACION.md) y bastará con cambiar estos valores.
NOMINA_PROVIDER=mock
FACTURACION_PROVIDER=mock
